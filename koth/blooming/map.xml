<map proto="1.5.1">
<name>Blooming</name>
<version>1.0.2</version>
<objective>Reach 750 points before the opposing team!</objective>
<include id="gapple-kill-reward"/>
<authors>
    <author uuid="bbfac3db-dd46-4996-b936-0e2432f33285"/> <!-- Valky -->
	<author uuid="770d4106-52cb-4c04-a771-4987330be3ec"/> <!-- NonSense -->
</authors>
<teams>
    <team id="blue" color="blue" max="5" max-overfill="5">Blue</team>
    <team id="red" color="dark red" max="5" max-overfill="5">Red</team>
</teams>
<kits>
    <kit id="conquest">
        <clear/>
        <item slot="0" unbreakable="true" material="stone sword"/>
        <item slot="1" unbreakable="true" material="bow"/>
        <item slot="2" material="golden apple"/>
        <item slot="8" amount="8" material="arrow"/>
        <helmet locked="true" unbreakable="true" team-color="true" material="leather helmet"/>
        <chestplate locked="true" unbreakable="true" team-color="true" material="leather chestplate"/>
        <leggings locked="true" unbreakable="true" material="chainmail leggings">
            <enchantment level="4">projectile_protection</enchantment>
        </leggings>
        <boots locked="true" unbreakable="true" material="iron boots">
            <enchantment>feather_falling</enchantment>
            <enchantment>fire_protection</enchantment>
        </boots>
        <effect duration="1s" amplifier="0">health boost</effect>
        <effect duration="1s" amplifier="10">regeneration</effect>
        <game-mode>adventure</game-mode>
    </kit>
    <kit id="spawn-kit" parent="conquest">
        <effect duration="2s" amplifier="255">resistance</effect>
    </kit>
</kits>
<spawns>
    <default>
        <region yaw="-90">
            <point>10.5,31,-52.5</point>
        </region>
    </default>
    <spawn team="blue" kit="spawn-kit">
        <region yaw="0">
            <point>42,16,-83</point>
        </region>
    </spawn>
    <spawn team="red" kit="spawn-kit">
        <region yaw="180">
            <point>42,16,-16</point>
        </region>
    </spawn>
</spawns>
<regions>
    <cuboid id="cap-region-mid" min="46,10,-46" max="39,13,-53"/>
    <cuboid id="cap-region-east" min="66,21,-50" max="73,17,-43"/>
    <cuboid id="cap-region-west" min="19,21,-49" max="12,17,-56"/>
    <cuboid id="captured-region-west" min="8,33,-31" max="23,16,-65"/>
    <cuboid id="captured-region-mid" min="46,8,-46" max="39,30,-53"/>
    <cuboid id="captured-region-east" min="77,33,-66" max="62,16,-34"/>
    <complement id="red-field-lower-region">
        <cuboid min="82,0,-117" max="3,28,-192"/>
        <!-- Hills -->
        <cuboid min="46,10,-151" max="39,11,-158"/>
        <cuboid min="66,18,-155" max="73,17,-148"/>
        <cuboid min="19,18,-154" max="12,17,-161"/>
        <!-- Hills captured regions-->
        <cuboid min="8,26,-140" max="9,19,-141"/>
        <cuboid min="8,26,-147" max="9,19,-148"/>
        <cuboid min="8,26,-167" max="9,19,-168"/>	
        <cuboid min="77,26,-141" max="76,19,-142"/>		
        <cuboid min="77,26,-161" max="76,19,-162"/>
        <cuboid min="77,26,-168" max="76,19,-169"/>
        <cuboid min="67,26,-140" max="65,28,-144"/>
        <cuboid min="63,28,-143" max="65,26,-141"/>	
        <cuboid min="64,27,-140" max="65,26,-144"/>
        <cuboid min="22,26,-165" max="18,28,-169"/>
        <!-- Exclude air-->	
        <cuboid min="35,18,-146" max="37,15,-147"/>		
    </complement>
    <cuboid id="red-field-air-region" min="35,18,-146" max="37,15,-147"/>
    <complement id="red-field-upper-region">
        <cuboid min="82,28,-117" max="3,60,-192"/>
		<!-- Hills captured regions-->
        <cuboid min="67,28,-140" max="65,30,-144"/>
        <cuboid min="63,29,-143" max="65,28,-141"/>	
        <cuboid min="22,28,-165" max="18,30,-169"/>
        <!-- Exclude towers-->
        <cuboid min="68,28,-135" max="50,57,-123"/>
        <cuboid min="64,28,-168" max="46,57,-190"/>
    </complement>
    <union id="red-field-towers-region">
        <cuboid min="68,28,-135" max="50,57,-123"/>
        <cuboid min="64,28,-168" max="46,57,-190"/>
    </union>
    <complement id="blue-field-lower-region">
        <cuboid min="82,0,93" max="3,28,18"/>
        <!-- Hills -->
        <cuboid min="46,10,59" max="39,11,52"/>
        <cuboid min="66,18,55" max="73,17,62"/>
        <cuboid min="19,18,56" max="12,17,49"/>
        <!-- Hills captured regions-->
        <cuboid min="8,26,70" max="9,19,69"/>
        <cuboid min="8,26,63" max="9,19,62"/>
        <cuboid min="8,26,43" max="9,19,42"/>	
        <cuboid min="77,26,69" max="76,19,68"/>		
        <cuboid min="77,26,49" max="76,19,48"/>
        <cuboid min="77,26,42" max="76,19,41"/>
        <cuboid min="18,26,45" max="20,28,41"/>
        <cuboid min="20,28,44" max="22,26,42"/>	
        <cuboid min="21,27,41" max="20,26,45"/>
        <cuboid min="67,26,66" max="63,38,70"/>	
        <!-- Exclude air-->
        <cuboid min="48,18,48" max="50,15,47"/>
    </complement>
    <cuboid id="blue-field-air-region" min="48,18,48" max="50,15,47"/>
    <complement id="blue-field-upper-region">
        <cuboid min="82,28,93" max="3,60,18"/>
        <!-- Hills captured regions-->
        <cuboid min="18,28,45" max="20,30,41"/>
        <cuboid min="20,29,44" max="22,28,42"/>	
        <cuboid min="67,28,66" max="63,30,70"/>
        <!-- Exclude towers-->		
        <cuboid min="17,28,36" max="35,57,24"/>
        <cuboid min="20,28,69" max="42,57,91"/>
    </complement>
    <union id="blue-field-towers-region">
        <cuboid min="17,28,36" max="35,57,24"/>
        <cuboid min="20,28,69" max="42,57,91"/>
    </union>	
    <apply block="never"/>
</regions>
<control-points required="false" capture-time="5s" points="1" time-multiplier="0" show-progress="true" neutral-state="true" incremental="true" permanent="false">
    <control-point name="West Hill" capture="cap-region-west" progress="cap-region-west" captured="captured-region-west"/>
    <control-point id="mid" name="Mid Hill" capture="cap-region-mid" progress="cap-region-mid" captured="captured-region-mid"/>
    <control-point name="East Hill" capture="cap-region-east" progress="cap-region-east" captured="captured-region-east"/>
</control-points>
<score>
    <limit>750</limit>
</score>
<toolrepair>
    <tool>stone sword</tool>
    <tool>bow</tool>
</toolrepair>
<itemremove>
    <item>leather helmet</item>
    <item>leather chestplate</item>
    <item>chainmail leggings</item>
    <item>iron boots</item>
    <item>seeds</item>
    <item>red rose</item>
    <item>sapling</item>
    <item>stone button</item>
	<item>water lily</item>
	<item>trap door</item>
</itemremove>
<itemkeep>
    <item>golden apple</item>
    <item>arrow</item>
</itemkeep>
<hunger>
    <depletion>off</depletion>
</hunger>
<respawn delay="6s" auto="true" blackout="true"/>
<kill-reward>
    <item amount="4" material="arrow"/>
</kill-reward>
<!-- Implement dynamic map changes-->
<structures>
    <structure id="red-field-lower" region="red-field-lower-region" air="false"/>
    <structure id="blue-field-lower" region="blue-field-lower-region" air="false"/>
    <structure id="red-field-air" region="red-field-air-region" air="true"/>
    <structure id="blue-field-air" region="blue-field-air-region" air="true"/>
    <structure id="red-field-upper" region="red-field-upper-region" air="false"/>
    <structure id="blue-field-upper" region="blue-field-upper-region" air="false"/>
    <structure id="red-field-towers" region="red-field-towers-region" air="true"/>
    <structure id="blue-field-towers" region="blue-field-towers-region" air="true"/>
    <!-- Paste structures sequentially to improve performance-->
    <dynamic structure="red-field-lower" offset="0,0,105" update="false">
        <trigger><captured team="red">mid</captured></trigger>
    </dynamic>
    <dynamic structure="blue-field-lower" offset="0,0,-105" update="false">	
        <trigger><captured team="blue">mid</captured></trigger>
    </dynamic>
    <dynamic structure="red-field-air" offset="0,0,105">
        <trigger><captured team="red">mid</captured></trigger>
    </dynamic>
    <dynamic structure="blue-field-air" offset="0,0,-105">	
        <trigger><captured team="blue">mid</captured></trigger>
    </dynamic>		
    <dynamic structure="red-field-upper" offset="0,0,105" update="false">
        <trigger><after duration="0.2s"><captured team="red">mid</captured></after></trigger>
    </dynamic>
    <dynamic structure="blue-field-upper" offset="0,0,-105" update="false">	
        <trigger><after duration="0.2s"><captured team="blue">mid</captured></after></trigger>
    </dynamic>	
    <dynamic structure="red-field-towers" offset="0,0,105" update="false">
        <trigger><after duration="0.4s"><captured team="red">mid</captured></after></trigger>
    </dynamic>
    <dynamic structure="blue-field-towers" offset="0,0,-105" update="false">	
        <trigger><after duration="0.4s"><captured team="blue">mid</captured></after></trigger>
    </dynamic>	
</structures>
</map>