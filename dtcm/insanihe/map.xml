<map proto="1.5.0">
<name>Insanihe</name>
<version>1.0.8</version>
<objective>Destroy both monuments, before the enemy destroys yours</objective>
<created>2016-09-24</created>
<include id="gapple-kill-reward"/>
<authors>
    <author uuid="b03360db-b8cd-49de-8ba1-b7920c2238a9" contribution="Making of map and XML"/> <!-- Obelistics -->
</authors>
<teams>
    <team id="red-team" color="dark red" max="12">Red</team>
    <team id="blue-team" color="blue" max="12">Blue</team>
</teams>
<kits>
    <kit id="spawn-kit">
        <clear/>
        <item slot="0" unbreakable="true" material="iron sword"/>
        <item slot="1" unbreakable="true" material="bow"/>
        <item slot="2" unbreakable="true" material="iron pickaxe"/>
        <item slot="3" unbreakable="true" material="iron axe"/>
        <item slot="4" material="wood" damage="1" amount="16"/>
        <item slot="5" material="stained clay" team-color="true" amount="24"/>
        <item slot="6" material="arrow" amount="16"/>
        <item slot="8" material="golden apple"/>
        <helmet unbreakable="true" team-color="true" material="leather helmet"/>
        <chestplate unbreakable="true" team-color="true" material="leather chestplate"/>
        <boots unbreakable="true" team-color="true" material="leather boots"/>
    </kit>
</kits>
<spawns>
    <spawn team="red-team" kit="spawn-kit" yaw="90">
        <region>
            <cylinder base="-85.5,6,-348.5" radius="0.5" height="0"/>
        </region>
    </spawn>
    <spawn team="blue-team" kit="spawn-kit" yaw="-90">
        <region>
            <cylinder base="-219.5,6,-348.5" radius="0.5" height="0"/>
        </region>
    </spawn>
    <default>
        <region>
            <cylinder base="-152.5,23,-388.5" radius="2" height="0"/>
        </region>
    </default>
</spawns>
<regions>
    <negative id="not-build-area">
        <rectangle min="-189,-324" max="-116,-373"/>
    </negative>
    <apply block="deny(void)" region="not-build-area" message="You may not modify this area!"/>
</regions>
<destroyables materials="coal block" show-progress="true" repairable="false">
    <destroyable name="Left Monument" owner="red-team">
        <region>
            <cylinder base="-124.5,4,-339.5" radius="2" height="7"/>
        </region>
    </destroyable>
    <destroyable name="Left Monument" owner="blue-team">
        <region>
            <cylinder base="-180.5,4,-357.5" radius="2" height="7"/>
        </region>
    </destroyable>
    <destroyable name="Right Monument" owner="red-team">
        <region>
            <cylinder base="-124.5,4,-357.5" radius="2" height="7"/>
        </region>
    </destroyable>
    <destroyable name="Right Monument" owner="blue-team">
        <region>
            <cylinder base="-180.5,4,-339.5" radius="2" height="7"/>
        </region>
    </destroyable>
</destroyables>
<toolrepair>
    <tool>iron sword</tool>
    <tool>bow</tool>
    <tool>iron pickaxe</tool>
    <tool>iron axe</tool>
</toolrepair>
<itemkeep>
    <item>wood</item>
    <item>stained clay</item>
    <item>arrow</item>
    <item>golden apple</item>
</itemkeep>
<itemremove>
    <item>nether brick</item>
    <item>sandstone</item>
    <item>ender stone</item>
    <item>leather helmet</item>
    <item>leather chestplate</item>
    <item>leather boots</item>
    <item>coal block</item>
    <item>string</item>
</itemremove>
<kill-rewards>
    <!-- 1 Kill -->
    <kill-reward>
        <item material="wood" damage="1" amount="8"/>
        <item material="stained clay" team-color="true" amount="12"/>
        <item material="arrow" amount="4"/>
    </kill-reward>
    <!-- 5 Kills -->
    <kill-reward>
        <filter>
            <kill-streak count="5" repeat="true"/>
        </filter>
        <item material="web" amount="4"/>
    </kill-reward>
</kill-rewards>
<maxbuildheight>18</maxbuildheight>
<hunger>
    <depletion>off</depletion>
</hunger>
</map>
