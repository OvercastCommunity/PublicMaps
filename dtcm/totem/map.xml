<map proto="1.5.0">
<name>Totem</name>
<version>1.2.7</version>
<include id="gapple-kill-reward"/>
<objective>Destroy the enemies monument and core.</objective>
<authors>
    <author uuid="b03360db-b8cd-49de-8ba1-b7920c2238a9" contribution="Map building and XML"/> <!-- Obelistics -->
    <author uuid="fe3608b7-d105-4029-8800-34b3147065b6" contribution="Map design and building"/> <!-- rockymine -->
</authors>
<broadcasts>
    <tip after="1m" every="4m">Iron can only be found next to spawn</tip>
</broadcasts>
<teams>
    <team id="red-team" color="dark red" max="20">Red</team>
    <team id="blue-team" color="blue" max="20">Blue</team>
</teams>
<spawns>
    <spawn team="red-team" kit="spawn-kit" yaw="135">
        <regions>
            <cuboid min="-178.5,15,-28.5" max="-175.5,15,-25.5"/>
        </regions>
    </spawn>
    <spawn team="blue-team" kit="spawn-kit" yaw="-45">
        <regions>
            <cuboid min="-285.5,15,-193.5" max="-288.5,15,-196.5"/>
        </regions>
    </spawn>
    <default yaw="-45">
        <regions>
            <cylinder base="-232,56,-111" radius="2" height="0"/>
        </regions>
    </default>
</spawns>
<kits>
    <kit id="spawn-kit">
        <clear/>
        <item slot="0" material="iron sword" unbreakable="true"/>
        <item slot="1" material="bow" unbreakable="true" enchantment="infinity"/>
        <item slot="2" material="diamond pickaxe" unbreakable="true"/>
        <item slot="3" material="iron axe" unbreakable="true"/>
        <item slot="4" unbreakable="true" material="iron spade"/>
        <item slot="5" material="shears" unbreakable="true" enchantment="efficiency"/>
        <item slot="6" material="wood" damage="2" amount="64"/>
        <item slot="7" material="stained clay" team-color="true" amount="32"/>
        <item slot="8" material="golden apple"/>
        <item slot="28" material="arrow"/>
        <chestplate material="leather chestplate" team-color="true" unbreakable="true" prevent-sharing="true"/>
        <boots material="leather boots" team-color="true" unbreakable="true" prevent-sharing="true"/>
        <helmet material="leather helmet" team-color="true" unbreakable="true" prevent-sharing="true"/>
        <effect duration="3s" amplifier="255">resistance</effect>
    </kit>
</kits>
<filters>
    <team id="only-red">red-team</team>
    <team id="only-blue">blue-team</team>
    <material id="iron-only">iron block</material>
    <deny id="deny-players">
        <participating/>
    </deny>
    <any id="leaves">
        <material>leaves</material>
        <material>log</material>
    </any>
</filters>
<regions>
    <union id="build-region">
        <rectangle min="-208,-189" max="-220,-177"/>
        <rectangle min="-232,-177" max="-220,-153"/>
        <rectangle min="-232,-177" max="-244,-189"/>
        <rectangle min="-232,-189" max="-220,-195"/>
        <rectangle min="-232,-129" max="-256,-141"/>
        <rectangle min="-208,-93" max="-232,-81"/>
        <rectangle min="-232,-69" max="-244,-45"/>
        <rectangle min="-232,-45" max="-220,-33"/>
        <rectangle min="-232,-33" max="-244,-27"/>
        <rectangle min="-244,-33" max="-256,-45"/>
    </union>
    <union id="spawn-regions">
        <rectangle id="red-spawn-region" min="-160,-21" max="-184,-45"/>
        <rectangle id="blue-spawn-region" min="-280,-177" max="-304,-201"/>
    </union>
    <union id="red-block-region">
        <rectangle min="-196,-45" max="-184,-21"/>
    </union>
    <union id="blue-block-region">
        <rectangle min="-267,-177" max="-280,-201"/>
    </union>
    <apply enter="only-blue" region="blue-spawn-region" message="You may not enter Blue's spawn"/>
    <apply enter="only-red" region="red-spawn-region" message="You may not enter Red's spawn"/>
    <apply block-place="deny-players" block-break="iron-only" region="spawn-regions" message="You can only break iron blocks in spawn."/>
    <apply block="always" region="build-region"/>
    <apply block-break="always"/>
    <apply block="deny(void)" message="You may not modify the void"/>
</regions>
<destroyables name="Monument" materials="emerald block">
    <destroyable owner="red-team">
        <region>
            <cuboid min="-213,23,-5" max="-211,20,-3"/>
        </region>
    </destroyable>
    <destroyable owner="blue-team">
        <region>
            <cuboid min="-251,23,-217" max="-253,20,-219"/>
        </region>
    </destroyable>
</destroyables>
<cores material="obsidian" leak="4" mode-changes="true">
    <core team="blue-team">
        <region>
            <cuboid min="-200,18,-169" max="-204,14,-173"/>
        </region>
    </core>
    <core team="red-team">
        <region>
            <cuboid min="-264,18,-53" max="-260,14,-49"/>
        </region>
    </core>
</cores>
<modes>
    <mode id="gold-mode" after="20m" material="gold block" name="`6GOLD CORE MODE"/>
    <mode id="ice-mode" after="40m" material="packed ice" name="`3PACKED ICE CORE MODE"/>
</modes>
<kill-rewards>
    <kill-reward>
        <item amount="16" damage="2" material="wood"/>
    </kill-reward>
</kill-rewards>
<itemkeep>
    <item>golden apple</item>
    <item>wood</item>
</itemkeep>
<toolrepair>
    <tool>iron sword</tool>
    <tool>bow</tool>
    <tool>diamond pickaxe</tool>
    <tool>iron axe</tool>
    <tool>iron spade</tool>
    <tool>shears</tool>
    <tool>arrow</tool>
</toolrepair>
<itemremove>
    <item>stone</item>
    <item>leaves</item>
    <item>long grass</item>
    <item>seeds</item>
    <item>stained clay</item>
    <item>emerald block</item>
    <item>dirt</item>
    <item>grass</item>
    <item>step</item>
    <item>double step</item>
    <item>wool</item>
    <item>clay</item>
    <item>coal block</item>
    <item>leather chestplate</item>
    <item>leather boots</item>
    <item>leather helmet</item>
    <item>obsidian</item>
    <item>gold block</item>
    <item>clay ball</item>
    <item>string</item>
</itemremove>
<renewables>
    <renewable region="spawn-regions" renew-filter="iron-only" interval="3" grow="false" particles="true" sound="true"/>
</renewables>
<hunger>
    <depletion>off</depletion>
</hunger>
<maxbuildheight>32</maxbuildheight>
</map>
