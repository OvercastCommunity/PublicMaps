<map proto="1.5.0">
<name>Thorns II</name>
<created>2015-05-08</created>
<version>1.0.4</version>
<objective>Leak both enemy cores!</objective>
<include id="gapple-kill-reward"/>
<phase>staging</phase>
<authors>
    <author uuid="fe3608b7-d105-4029-8800-34b3147065b6"/> <!-- rockymine -->
</authors>
<contributors>
    <contributor uuid="10c1b730-49b9-4f75-9212-91facc371477"/> <!-- Qixit -->
    <contributor uuid="060baa18-2852-40d8-afcb-e61607c04be3"/> <!-- PepsiDog -->
</contributors>
<broadcasts>
    <tip after="30s" every="3m">Trade with villagers to upgrade your equipment!</tip>
</broadcasts>
<teams>
    <team id="cyan" color="dark aqua" max="20">Cyan</team>
    <team id="orange" color="gold" max="20">Orange</team>
</teams>
<kits>
    <kit id="spawn-kit">
        <item slot="0" unbreakable="true" material="stone sword"/>
        <item slot="1" unbreakable="true" material="bow"/>
        <item slot="28" amount="32" material="arrow"/>
        <item slot="2" unbreakable="true" material="stone pickaxe"/>
        <item slot="3" unbreakable="true" material="stone axe"/>
        <item slot="30" unbreakable="true" material="stone spade"/>
        <item slot="4" amount="24" damage="2" material="wood"/>
        <item slot="5" amount="16" damage="2" material="leaves"/>
        <item slot="6" material="shears">
            <enchantment>unbreaking</enchantment>
        </item>
        <item slot="7" material="golden apple"/>
        <item slot="8" amount="64" material="golden carrot"/>
        <helmet team-color="true" unbreakable="true" material="leather helmet"/>
        <chestplate team-color="true" unbreakable="true" material="leather chestplate"/>
        <leggings unbreakable="true" material="gold leggings"/>
        <boots team-color="true" unbreakable="true" material="leather boots"/>
        <effect duration="5" amplifier="3">heal</effect>
        <effect duration="5" amplifier="5">damage resistance</effect>
    </kit>
</kits>
<spawns>
    <spawn team="cyan" kit="spawn-kit" yaw="90">
        <region>
            <point>-877,13,96</point>
        </region>
    </spawn>
    <spawn team="orange" kit="spawn-kit" yaw="-90">
        <region>
            <point>-850,13,-21</point>
        </region>
    </spawn>
    <default yaw="-90">
        <region>
            <block>-944,61,37</block>
        </region>
    </default>
</spawns>
<filters>
    <team id="only-cyan">cyan</team>
    <team id="only-orange">orange</team>
</filters>
<regions>
    <union id="no-build">
        <union id="spawns">
            <rectangle id="cyan-spawn" min="-883,103" max="-875,94"/>
            <rectangle id="orange-spawn" min="-843,-28" max="-851,-19"/>
        </union>
        <union id="villager-boxes">
            <rectangle min="-881,-33" max="-875,-28"/>
            <rectangle min="-852,103" max="-846,108"/>
        </union>
        <union id="signs">
            <cuboid min="-852,12,-36" max="-846,16,-34"/>
            <cuboid min="-881,12,109" max="-875,16,111"/>
        </union>
    </union>
    <union id="cores">
        <cuboid id="orange-a" min="-891,16,-18" max="-888,20,-15"/>
        <cuboid id="orange-b" min="-838,20,-10" max="-835,24,-7"/>
        <cuboid id="cyan-a" min="-839,16,90" max="-836,20,93"/>
        <cuboid id="cyan-b" min="-892,20,82" max="-889,24,85"/>
    </union>
    <negative id="void-area">
        <rectangle min="-914,72" max="-814,2"/>
    </negative>
    <apply enter="only-orange" message="You may not enter the enemy's base (hill)!" region="orange-spawn"/>
    <apply enter="only-cyan" message="You may not enter the enemy's base (hill)!" region="cyan-spawn"/>
    <apply block="never" message="You may not break or place blocks here!" region="no-build"/>
    <apply block="deny(void)" message="You may not build outside of the savanna!" region="void-area"/>
</regions>
<cores mode-changes="true" material="obsidian" leak="3">
    <core name="Core A" team="cyan" region="cyan-a"/>
    <core name="Core B" team="cyan" region="cyan-b"/>
    <core name="Core A" team="orange" region="orange-a"/>
    <core name="Core B" team="orange" region="orange-b"/>
</cores>
<modes>
    <mode after="20m" material="ender stone" name="`eENDER CORE MODE"/>
    <mode after="40m" material="gold block" name="`8GOLD CORE MODE"/>
</modes>
<kill-rewards>
    <kill-reward>
        <item material="emerald"/>
        <item amount="3" material="arrow"/>
        <item amount="4" damage="2" material="wood"/>
    </kill-reward>
</kill-rewards>
<toolrepair>
    <tool>stone sword</tool>
    <tool>bow</tool>
    <tool>golden apple</tool>
</toolrepair>
<itemremove>
    <item>stone pickaxe</item>
    <item>stone axe</item>
    <item>stone spade</item>
    <item>dirt</item>
    <item>seeds</item>
    <item>golden carrot</item>
    <item>shears</item>
    <item>arrow</item>
    <item>leather chestplate</item>
    <item>leather helmet</item>
    <item>leather boots</item>
    <item>iron sword</item>
    <item>iron axe</item>
    <item>obsidian</item>
    <item>ender stone</item>
    <item>gold block</item>
    <item>gold leggings</item>
</itemremove>
<itemkeep>
    <item>emerald</item>
    <item>emerald block</item>
    <item>iron ingot</item>
    <item>iron sword</item>
    <item>diamond pickaxe</item>
    <item>iron pickaxe</item>
</itemkeep>
<armorkeep>
    <item>gold boots</item>
    <item>gold helmet</item>
    <item>iron helmet</item>
    <item>iron chestplate</item>
    <item>iron leggings</item>
    <item>iron boots</item>
</armorkeep>
<crafting>
    <disable>emerald block</disable>
</crafting>
<maxbuildheight>33</maxbuildheight>
</map>
