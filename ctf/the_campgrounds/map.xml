<map proto="1.5.0">
<name>The Campgrounds</name>
<version>2.0</version>
<constant id="respawn-timer">4s</constant>
<constant id="override-itemkeep">true</constant>
<constant id="damage-resistance">5s</constant>
<include id="conquest"/>
<objective>Capture the enemy team's flag as many times as possible within 12 minutes!</objective>
<time result="score" overtime="1m" max-overtime="2m">12m</time>
<authors>
    <author uuid="6bec5c3a-4934-4b19-9aa8-c7c569820f7d"/> <!-- Claf -->
    <author uuid="621b2aa8-4e5f-4ed8-bd36-0ae2f8952a06"/> <!-- Strangey -->
</authors>
<teams>
    <team id="blue-team" color="blue" max="16">Blue</team>
    <team id="red-team" color="dark red" max="16">Red</team>
</teams>
<kits>
    <kit id="spawn-kit" parent="base-kit">
        <item slot="3" unbreakable="true" material="shears"/>
        <item slot="4" amount="12" material="leaves"/>
        <action>
            <enchant-item ignore-metadata="true" enchantment="projectile_protection" level="2">
                <find material="chainmail leggings"/>
            </enchant-item>
        </action>
        <effect>speed</effect>
        <game-mode>survival</game-mode>
    </kit>
    <kit id="flag-kit">
        <!-- Just cancel out base kit speed -->
        <effect>slowness</effect>
    </kit>
</kits>
<spawns>
    <default>
        <region yaw="90">
            <cuboid min="-51,24,274" max="-52,24,273"/>
        </region>
    </default>
    <spawn team="blue-team" kit="spawn-kit">
        <region yaw="-90">
            <cylinder base="-80,1,308" radius="2" height="0"/>
        </region>
    </spawn>
    <spawn team="red-team" kit="spawn-kit">
        <region yaw="90">
            <cylinder base="-68,1,240" radius="2" height="0"/>
        </region>
    </spawn>
</spawns>
<regions>
    <cylinder id="blue-net" base="-118,5,337" radius="2" height="2"/>
    <cylinder id="red-net" base="-30,5,211" radius="2" height="2"/>
    <apply velocity="0.0,1.8,0.0">
        <region>
            <cuboid min="-61,1,278" max="-64,2,274"/>
            <cuboid min="-87,1,270" max="-84,2,274"/>
            <cuboid min="-55,1,242" max="-59,2,238"/>
            <cuboid min="-92,1,306" max="-89,2,310"/>
        </region>
    </apply>
    <apply velocity="0.0,1.3,0.0">
        <region>
            <cuboid min="-48,7,314" max="-52,8,310"/>
            <cuboid min="-99,7,234" max="-96,8,238"/>
        </region>
    </apply>
</regions>
<flags flag-proximity-metric="none" net-proximity-metric="none">
    <flag id="blue-flag" name="Blue Flag" owner="red-team" color="blue" carry-kit="flag-kit">
        <post pickup-filter="blue-team" recover-time="20s" respawn-time="15s">-29.5,6,210.5</post>
    </flag>
    <flag id="red-flag" name="Red Flag" owner="blue-team" color="red" carry-kit="flag-kit">
        <post pickup-filter="red-team" recover-time="20s" respawn-time="15s">-118.5,6,337.5</post>
    </flag>
    <flags points="1">
        <net region="blue-net" flag="blue-flag"/>
        <net region="red-net" flag="red-flag"/>
    </flags>
</flags>
<score>
    <mercy>3</mercy>
</score>
<toolrepair>
    <tool>shears</tool>
</toolrepair>
<itemremove>
    <item>sapling</item>
</itemremove>
<itemkeep>
    <item>stone sword</item>
    <item>bow</item>
    <item>shears</item>
    <item>golden apple</item>
    <item>arrow</item>
    <item>leaves</item>
</itemkeep>
<maxbuildheight>18</maxbuildheight>
<kill-rewards>
    <kill-reward>
        <item amount="6" material="leaves"/>
    </kill-reward>
</kill-rewards>
<disabledamage>
    <damage>fall</damage>
</disabledamage>
</map>
