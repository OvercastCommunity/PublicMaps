<map proto="1.5.0">
<name>Emission</name>
<version>1.3.0</version>
<objective>Control all five flags to win!</objective>
<created>2015-03-19</created>
<include id="gapple-kill-reward"/>
<include id="void-death"/>
<authors>
    <author uuid="fe3608b7-d105-4029-8800-34b3147065b6"/> <!-- rockymine -->
    <author uuid="dff980ed-9f69-491e-b79c-30c21350baf2"/> <!-- DoomyBoy -->
</authors>
<contributors>
    <contributor uuid="f690a591-348b-482e-a18d-7779d0c0a28c" contribution="Providing the working code"/> <!-- mitchiii -->
</contributors>
<teams>
    <team id="red" color="dark red" max="14">Red</team>
    <team id="blue" color="blue" max="14">Blue</team>
</teams>
<spawns>
    <spawn team="red" region="red-spawn" yaw="0" kit="players"/>
    <spawn team="blue" region="blue-spawn" yaw="180" kit="players"/>
    <default region="obs-spawn" yaw="-90" kit="obs"/>
</spawns>
<kits>
    <kit id="players">
        <clear/>
        <item slot="0" material="stone sword" unbreakable="true"/>
        <item slot="1" material="bow" unbreakable="true"/>
        <item slot="2" material="golden apple"/>
        <item slot="8" material="arrow" amount="36"/>
        <helmet material="leather helmet" team-color="true" unbreakable="true" locked="true"/>
        <chestplate material="leather chestplate" team-color="true" unbreakable="true" locked="true"/>
        <leggings material="chainmail leggings" unbreakable="true" locked="true">
            <enchantment level="3">projectile protection</enchantment>
        </leggings>
        <boots material="iron boots" unbreakable="true" locked="true"/>
        <effect duration="3" amplifier="5">resistance</effect>
        <effect>night vision</effect>
        <game-mode>adventure</game-mode>
    </kit>
    <kit id="obs">
        <effect>night vision</effect>
    </kit>
    <kit id="flag-pickup" force="true">
        <max-health>12</max-health>
        <effect duration="6s" amplifier="2">absorption</effect>
        <if min-server-version="1.9">
            <effect>glowing</effect>
        </if>
        <action filter="match-running">
            <set var="score" value="score + 1"/>
        </action>
    </kit>
    <kit id="flag-drop" force="true">
        <max-health>20</max-health>
        <if min-server-version="1.9">
            <effect duration="0s" amplifier="0">glowing</effect>
        </if>
        <action filter="match-running">
            <set var="score" value="score - 1"/>
        </action>
    </kit>
</kits>
<kill-rewards>
    <kill-reward>
        <item material="arrow" amount="12"/>
    </kill-reward>
</kill-rewards>
<filters>
    <players id="player-count-prerequisite" min="10" filter="participating"/>
    <all id="first-place">
        <rank>1</rank>
        <score>1..</score>
    </all>
    <after id="alternate-win-invisible-timer" duration="30s" filter="all(match-running, first-place, not(player-count-prerequisite))"/>
    <after id="alternate-win-red-timer" duration="45s" filter="all(match-running, alternate_win_team=${red})" message="`4Red `rwins in {0}"/>
    <after id="alternate-win-blue-timer" duration="45s" filter="all(match-running, alternate_win_team=${blue})" message="`9Blue `rwins in {0}"/>
</filters>
<regions>
    <block id="obs-spawn">-725.5,22,-130.5</block>
    <cuboid id="red-spawn" min="-693,6,-202" max="-691,6,-200"/>
    <cuboid id="blue-spawn" min="-672,6,-59" max="-674,6,-61"/>
    <apply block="never" use="never"/>
</regions>
<time>7m</time>
<score limit="5" display="circle"/>
<flags color="yellow" shared="true" pickup-kit="flag-pickup" drop-kit="flag-drop" allow-manual-drop="false">
    <flag name="Center Flag" id="center-flag">
        <post respawn-time="3s" recover-time="0s">-682.5,10,-130.5</post>
    </flag>
    <flag name="South Flag" id="south-flag">
        <post respawn-time="3s" recover-time="0s">-712.5,3,-90.5</post>
    </flag>
    <flag name="North Flag" id="north-flag">
        <post respawn-time="3s" recover-time="0s">-652.5,3,-170.5</post>
    </flag>
    <flag name="West Flag" id="west-flag">
        <post respawn-time="3s" recover-time="0s">-712.5,10,-130.5</post>
    </flag>
    <flag name="East Flag" id="east-flag">
        <post respawn-time="3s" recover-time="0s">-652.5,10,-130.5</post>
    </flag>
</flags>
<constants>
    <constant id="red">1</constant>
    <constant id="blue">2</constant>
</constants>
<variables>
    <variable id="alternate_win_team" scope="match"/>
</variables>
<replacements>
    <switch id="current_winner_judgement" scope="match" value="alternate_win_team">
        <case match="${red}" result="`4`lRed's judgement"/>
        <case match="${blue}" result="`9`lBlue's judgement"/>
    </switch>
    <switch id="current_winner" scope="match" value="alternate_win_team">
        <case match="${red}" result="`4Red"/>
        <case match="${blue}" result="`9Blue"/>
    </switch>
    <switch id="current_loser" scope="match" value="alternate_win_team">
        <case match="${red}" result="`9Blue"/>
        <case match="${blue}" result="`4Red"/>
    </switch>
</replacements>
<actions>
    <trigger scope="team" filter="all(match-running, not(alternate-win-invisible-timer))" action="alternate_win_team := 0"/>
    <trigger scope="team" filter="all(match-running, red, alternate-win-invisible-timer)" action="alternate_win_team := ${red}"/>
    <trigger scope="team" filter="all(match-running, blue, alternate-win-invisible-timer)" action="alternate_win_team := ${blue}"/>
    <trigger scope="match" filter="all(match-running, alternate-win-red-timer)" action="timelimit := 0"/>
    <trigger scope="match" filter="all(match-running, alternate-win-blue-timer)" action="timelimit := 0"/>
    <trigger scope="match" filter="all(match-running, not(alternate_win_team=0))">
        <action>
            <sound key="${entity.lightning_bolt.thunder}"/>
            <message text=" "/>
            <message text="`6» » » {0} `6« « «">
                <replacements>
                    <replacement id="0">current_winner_judgement</replacement>
                </replacements>
            </message>
            <switch-scope inner="team" filter="any(all(red, alternate_win_team=${red}), all(blue, alternate_win_team=${blue}))">
                <message text="`bHold more flags than {0} until the timer runs out to win.">
                    <replacements>
                        <replacement id="0">current_loser</replacement>
                    </replacements>
                </message>
            </switch-scope>
            <switch-scope inner="team" filter="any(all(red, alternate_win_team=${blue}), all(blue, alternate_win_team=${red}))">
                <message text="`bEliminate {0}'s flag carriers or collect more flags to prevent {0} from winning.">
                    <replacements>
                        <replacement id="0">current_loser</replacement>
                    </replacements>
                </message>
            </switch-scope>
            <switch-scope inner="player" filter="observing">
                <message text="{0} `bmust hold more flags then {1} until the timer runs out to win.">
                    <replacements>
                        <replacement id="0">current_winner</replacement>
                        <replacement id="1">current_loser</replacement>
                    </replacements>
                </message>
            </switch-scope>
            <message text=" "/>
        </action>
    </trigger>
</actions>
<toolrepair>
    <tool>stone sword</tool>
    <tool>bow</tool>
</toolrepair>
<itemremove>
    <item>leather helmet</item>
    <item>leather chestplate</item>
    <item>chainmail leggings</item>
    <item>iron boots</item>
    <item>arrow</item>
    <item>banner</item>
</itemremove>
<timelock>on</timelock>
<hunger>
    <depletion>off</depletion>
</hunger>
</map>
