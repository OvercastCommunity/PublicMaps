<map proto="1.5.0">
<name>Clearcut</name>
<version>2.2.1</version>
<variant id="christmas" world="christmas" override="true">Coldcut</variant>
<objective>Capture and place both of the enemy's wools!</objective>
<include id="gapple-kill-reward"/>
<authors>
    <author uuid="fe3608b7-d105-4029-8800-34b3147065b6"/> <!-- rockymine -->
    <author uuid="b03360db-b8cd-49de-8ba1-b7920c2238a9"/> <!-- Obelistics -->
    <author uuid="dff980ed-9f69-491e-b79c-30c21350baf2"/> <!-- DoomyBoy -->
</authors>
<if variant="christmas">
    <contributors>
        <contributor uuid="0c44ca5a-6a42-49b7-81f2-58dc6d2ae3e9" contribution="Christmas-ification"/> <!-- Xerocoles -->
    </contributors>
</if>
<teams>
    <team id="blue-team" color="blue" max="20">Blue</team>
    <team id="red-team" color="dark red" max="20">Red</team>
</teams>
<kits>
    <kit id="spawn-kit">
        <clear/>
        <item slot="0" unbreakable="true" material="iron sword"/>
        <item slot="1" unbreakable="true" material="bow">
            <enchantment>infinity</enchantment>
        </item>
        <item slot="28" material="arrow"/>
        <item slot="2" unbreakable="true" material="iron pickaxe">
            <enchantment>efficiency</enchantment>
        </item>
        <item slot="3" unbreakable="true" material="iron axe">
            <enchantment>efficiency</enchantment>
        </item>
        <item slot="30" unbreakable="true" material="iron spade"/>
        <if variant="default">
            <item slot="4" amount="64" damage="2" material="wood"/>
        </if>
        <if variant="christmas">
            <item slot="4" amount="64" damage="1" material="wood"/>
        </if>
        <item slot="5" amount="48" material="glass"/>
        <item slot="8" material="golden apple"/>
        <helmet unbreakable="true" team-color="true" material="leather helmet"/>
        <chestplate unbreakable="true" team-color="true" material="leather chestplate"/>
        <leggings unbreakable="true" team-color="true" material="leather leggings"/>
        <boots unbreakable="true" team-color="true" material="leather boots"/>
        <effect duration="2s" amplifier="5">resistance</effect>
    </kit>
</kits>
<spawns>
    <default>
        <region yaw="-90">
            <cylinder base="273.5,10,-10.5" radius="2" height="0"/>
        </region>
    </default>
    <spawn team="blue-team" kit="spawn-kit">
        <region yaw="180">
            <point>273.5,11.5,84.5</point>
        </region>
    </spawn>
    <spawn team="red-team" kit="spawn-kit">
        <region>
            <point>273.5,11.5,-105.5</point>
        </region>
    </spawn>
</spawns>
<filters>
    <all id="only-iron-regen">
        <material id="only-iron">iron block</material>
        <cause>world</cause>
    </all>
    <material id="chest">chest</material>
    <material id="stained-glass-filter">stained glass</material>
</filters>
<regions>
    <union id="spawners">
        <block>314,16,6</block>
        <block>314,17,6</block>
        <block>232,16,6</block>
        <block>232,17,6</block>
        <block>232,16,-28</block>
        <block>232,17,-28</block>
        <block>314,16,-28</block>
        <block>314,17,-28</block>
        <block>273,9,-11</block>
        <block>273,10,-11</block>
    </union>
    <union id="wool-room-protection">
        <cuboid min="199,16,78" max="193,14,71"/>
        <cuboid min="348,16,78" max="354,14,71"/>
        <cuboid min="348,16,-99" max="354,14,-92"/>
        <cuboid min="199,16,-99" max="193,14,-92"/>
    </union>
    <union id="iron-renew">
        <cuboid min="260.5,6,62.5" max="286.5,13,94.5"/>
        <cuboid min="260.5,6,-115.5" max="286.5,13,-83.5"/>
    </union>
    <union id="spawns">
        <rectangle id="blue-spawn" min="267,71" max="280,95"/>
        <rectangle id="red-spawn" min="280,-92" max="267,-115"/>
    </union>
    <union id="wool-rooms">
        <union id="blue-wools"> <!-- blue capture, red defend -->
            <rectangle id="magenta-wool" min="207,-89" max="191,-102"/>
            <rectangle id="pink-wool" min="340,-102" max="356,-89"/>
        </union>
        <union id="red-wools"> <!-- red capture, blue defend -->
            <rectangle id="cyan-wool" min="340,68" max="356,81"/>
            <rectangle id="light-blue-wool" min="207,81" max="191,68"/>
        </union>
    </union>
    <union id="no-monu">
        <!-- Blue -->
        <cuboid min="275,10,85" max="276,13,86"/>
        <cuboid min="271,10,85" max="272,13,86"/>
        <!-- Red -->
        <cuboid min="275,10,-106" max="276,13,-107"/>
        <cuboid min="271,10,-106" max="272,13,-107"/>
    </union>
    <complement id="void-area">
        <everywhere/>
        <!-- Blue -->
        <rectangle min="277,34" max="318,4"/>
        <rectangle min="270,34" max="229,4"/>
        <!-- Red -->
        <rectangle min="277,-55" max="318,-25"/>
        <rectangle min="270,-55" max="229,-25"/>
        <!-- Mid -->
        <rectangle min="235,-25" max="312,4"/>
    </complement>
    <cuboid id="floor" min="229,0,-55" max="318,1,34"/>
    <apply enter="never" region="no-monu" message="Do not block the wool monuments"/>
    <apply enter="deny(red-team)" use="deny(red-team)" region="blue-spawn" message="You may not enter the enemy team's spawn!"/>
    <apply enter="deny(blue-team)" use="deny(blue-team)" region="red-spawn" message="You may not enter the enemy team's spawn!"/>
    <apply enter="deny(red-team)" region="blue-wools" message="You may not enter your team's own wool rooms!"/>
    <apply enter="deny(blue-team)" region="red-wools" message="You may not enter your team's own wool rooms!"/>
    <apply block="never" region="spawners" message="You may not break the spawners!"/>
    <apply block="never" region="wool-room-protection" message="You may not break blocks here!"/>
    <apply block="deny(chest)" region="wool-rooms" message="You may not break or place chests in the wool rooms!"/>
    <apply block="deny(red-team)" use="deny(red-team)" region="blue-wools" message="You may not interfere with your team's own wool rooms!"/>
    <apply block="deny(blue-team)" use="deny(blue-team)" region="red-wools" message="You may not interfere with your team's own wool rooms!"/>
    <apply block-break="only-iron" block-place="only-iron-regen" region="spawns" message="You may not modify the spawns!"/>
    <apply block-place="deny(void)" region="void-area" message="You may not build in the void!"/>
</regions>
<renewables>
    <renewable region="iron-renew" renew-filter="only-iron"/>
</renewables>
<wools>
    <wool team="blue-team" color="magenta" location="194.5,16,-94.5">
        <monument>
            <block>271.5,12,85.5</block>
        </monument>
    </wool>
    <wool team="blue-team" color="pink" location="352.5,16,-94.5">
        <monument>
            <block>275.5,12,85.5</block>
        </monument>
    </wool>
    <wool team="red-team" color="cyan" location="352.5,16,73.5">
        <monument>
            <block>275.5,12,-106.5</block>
        </monument>
    </wool>
    <wool team="red-team" color="light blue" location="194.5,16,73.5">
        <monument>
            <block>271.5,12,-106.5</block>
        </monument>
    </wool>
</wools>
<actions>
    <!-- show the build area and clear it on the game starting -->
    <trigger scope="match">
        <filter>
            <match-started/>
        </filter>
        <action>
            <fill material="air" region="floor" filter="stained-glass-filter"/>
        </action>
    </trigger>
</actions>
<toolrepair>
    <tool>iron sword</tool>
    <tool>bow</tool>
    <tool>iron pickaxe</tool>
    <tool>iron axe</tool>
    <tool>iron spade</tool>
    <tool>arrow</tool>
</toolrepair>
<itemremove>
    <item>leather helmet</item>
    <item>leather chestplate</item>
    <item>leather leggings</item>
    <item>leather boots</item>
    <item>string</item>
    <item>sapling</item>
    <item>apple</item>
    <item>long grass</item>
    <item>seeds</item>
    <item>red rose</item>
    <item>red mushroom</item>
    <item>clay ball</item>
    <item>iron ore</item>
    <item>coal</item>
    <item>redstone</item>
    <item>redstone torch on</item>
    <if variant="christmas">
        <item>snow ball</item>
        <item>emerald</item>
    </if>
</itemremove>
<block-drops>
    <rule>
        <filter>
            <any>
                <if variant="default">
                    <material>wood:2</material>
                </if>
                <if variant="christmas">
                    <material>wood:1</material>
                </if>
                <material>glass</material>
            </any>
        </filter>
        <drops>
            <item chance="0" material="glass"/>
        </drops>
    </rule>
    <rule wrong-tool="false">
        <filter>
            <any>
                <material>stone:0</material>
                <material>stone:5</material>
            </any>
        </filter>
        <drops>
            <item material="cobblestone"/>
        </drops>
    </rule>
</block-drops>
<itemkeep>
    <item>golden apple</item>
    <if variant="default">
        <item>wood:2</item>
    </if>
    <if variant="christmas">
        <item>wood:1</item>
    </if>
    <item>glass</item>
</itemkeep>
<kill-rewards>
    <kill-reward>
        <if variant="default">
            <item amount="24" damage="2" material="wood"/>
        </if>
        <if variant="christmas">
            <item amount="24" damage="1" material="wood"/>
        </if>
        <item amount="16" material="glass"/>
    </kill-reward>
</kill-rewards>
<maxbuildheight>28</maxbuildheight>
<hunger>
    <depletion>off</depletion>
</hunger>
</map>
