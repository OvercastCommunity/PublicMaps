<map proto="1.5.0">
<name>Rooted</name>
<version>2.1.3</version>
<objective>Capture the enemy team's two wools and place them on your victory monument!</objective>
<phase>staging</phase>
<include id="gapple-kill-reward"/>
<authors>
    <author uuid="fe3608b7-d105-4029-8800-34b3147065b6"/> <!-- rockymine -->
</authors>
<teams>
    <team id="red-team" color="dark red" max="12">Red</team>
    <team id="blue-team" color="blue" max="12">Blue</team>
</teams>
<kits>
    <kit id="spawn-kit">
        <clear/>
        <item slot="0" unbreakable="true" material="stone sword"/>
        <item slot="1" unbreakable="true" enchantment="infinity" material="bow"/>
        <item slot="28" material="arrow"/>
        <item slot="2" unbreakable="true" enchantment="efficiency" material="iron pickaxe"/>
        <item slot="3" unbreakable="true" enchantment="efficiency" material="stone axe"/>
        <item slot="30" unbreakable="true" material="iron spade"/>
        <item slot="4" amount="64" damage="5" material="wood"/>
        <item slot="5" amount="32" material="leaves"/>
        <item slot="6" unbreakable="true" material="shears"/>
        <item slot="8" material="golden apple"/>
        <item slot="17" amount="4" material="web"/>
        <helmet unbreakable="true" team-color="true" material="leather helmet"/>
        <chestplate unbreakable="true" team-color="true" material="leather chestplate"/>
        <leggings unbreakable="true" enchantment="protection projectile" material="chainmail leggings"/>
        <boots unbreakable="true" team-color="true" material="leather boots"/>
        <effect duration="5s" amplifier="255">heal</effect>
        <effect duration="5s" amplifier="255">damage resistance</effect>
    </kit>
</kits>
<spawns>
    <spawn team="red-team" kit="spawn-kit" yaw="180">
        <region>
            <point>0.5,7,95.5</point>  
        </region>	
    </spawn>
    <spawn team="blue-team" kit="spawn-kit" yaw="0">
        <region>	    
            <point>0.5,7,-94.5</point>
        </region>	
    </spawn>
    <default yaw="90">
        <region>
            <cuboid min="36,36,12" max="35,36,-11"/>
        </region>
    </default>
</spawns>
<filters>
    <blocks id="wool-rooms-blocks" region="wool-rooms-blocks-region">
        <any>
            <material>air</material>
            <material>web</material>
            <material>leaves</material>
            <material>long grass</material>
            <material>red rose</material>
        </any>
    </blocks>
    <deny id="deny-void-break">
        <all>
            <material>web</material>
            <void/>
        </all>
    </deny>
</filters>
<regions>
    <negative id="void-area">
        <rectangle id="buildable-area" min="-19,-53" max="20,54"/>
    </negative>		    
    <union id="spawns">
        <rectangle id="red-spawn" min="-4,62" max="5,101"/>
        <rectangle id="blue-spawn" min="5,-61" max="-4,-100"/>
    </union>
    <union id="wool-rooms">
        <union id="blue-wool-rooms"> <!-- red capture, blue defend -->
            <rectangle id="lime-wool-room" min="21,-89" max="8,-100"/>
            <rectangle id="green-wool-room" min="-20,-89" max="-7,-100"/>
        </union>
        <union id="red-wool-rooms">  <!-- blue capture, red defend -->
            <rectangle id="light-grey-wool-room" min="-20,90" max="-7,101"/>
            <rectangle id="light-blue-wool-room" min="21,90" max="8,101"/>
        </union>
    </union>
    <union id="wool-rooms-blocks-region">
        <union>
            <cuboid min="21,0,-89" max="8,20,-100"/> <!-- lime -->
            <cuboid min="-20,0,-89" max="-7,20,-100"/> <!-- green -->
        </union>
        <union>  
            <cuboid min="-20,0,90" max="-7,20,101"/> <!-- light grey -->
            <cuboid min="21,0,90" max="8,20,101"/> <!-- light blue -->
        </union>
    </union>
    <point id="lime-wool-spawn">16.5,5,-94.5</point>
    <point id="green-wool-spawn">-15.5,5,-94.5</point>
    <point id="light-grey-wool-spawn">-15.5,5,95.5</point>
    <point id="light-blue-wool-spawn">16.5,5,95.5</point>
    <apply enter="red-team" region="red-spawn" message="You may not enter the enemy team's spawn!"/>
    <apply enter="blue-team" region="blue-spawn" message="You may not enter the enemy team's spawn!"/>
    <apply enter="red-team" region="blue-wool-rooms" message="You may not enter your own wool room!"/>
    <apply enter="blue-team" region="red-wool-rooms" message="You may not enter your own wool room!"/>
    <apply block="deny(blue-team)" region="blue-wool-rooms" message="You may not modify your own wool room!"/>
    <apply block="deny(red-team)" region="red-wool-rooms" message="You may not modify your own wool room!"/>
    <apply block="wool-rooms-blocks" region="wool-rooms-blocks-region" message="You may not modify the wool room!"/>
    <apply block="never" region="spawns" message="You may not modify the spawns!"/>
    <apply block-place="deny(void)" block-break="deny-void-break" region="void-area" message="You may not modify the void area!"/>
</regions>
<wools craftable="false">
    <wools team="red-team">
        <wool color="lime" location="16.5,5,-94.5">
            <monument>
                <block>2,6,78</block>
            </monument>
        </wool>
        <wool color="green" location="-15.5,5,-94.5">
            <monument>
                <block>-2,6,78</block>
            </monument>
        </wool>
    </wools>
    <wools team="blue-team">
        <wool color="silver" location="-15.5,5,95.5">
            <monument>
                <block>-2,6,-78</block>
            </monument>
        </wool>
        <wool color="light blue" location="16.5,5,95.5">
            <monument>
                <block>2,6,-78</block>
            </monument>
        </wool>
    </wools>
</wools>
<spawners>
    <spawner spawn-region="lime-wool-spawn" player-region="lime-wool-room" delay="3s" max-entities="4">
        <item material="wool" amount="1" damage="5"/>
    </spawner>
    <spawner spawn-region="green-wool-spawn" player-region="green-wool-room" delay="3s" max-entities="4">
        <item material="wool" amount="1" damage="13"/>
    </spawner>
    <spawner spawn-region="light-grey-wool-spawn" player-region="light-grey-wool-room" delay="3s" max-entities="4">
        <item material="wool" amount="1" damage="8"/>
    </spawner>
    <spawner spawn-region="light-blue-wool-spawn" player-region="light-blue-wool-room" delay="3s" max-entities="4">
        <item material="wool" amount="1" damage="3"/>
    </spawner>
</spawners>
<toolrepair>
    <tool>stone sword</tool>
    <tool>bow</tool>
    <tool>shears</tool>
    <tool>arrow</tool>
    <tool>stone axe</tool>
    <tool>iron pickaxe</tool>
    <tool>iron spade</tool>
</toolrepair>
<itemremove>
    <item>leather helmet</item>
    <item>leather chestplate</item>
    <item>chainmail leggings</item>
    <item>leather boots</item>
    <item>stone</item>
    <item>dirt</item>
    <item>red rose</item>
    <item>seeds</item>
    <item>sapling</item>
    <item>long grass</item>
    <item>apple</item>
    <item>string</item>
    <item>web</item>
    <item>flint</item>
</itemremove>
<itemkeep>
    <item>wood</item>
    <item>leaves</item>
    <item>golden apple</item>
</itemkeep>
<kill-rewards>
    <kill-reward>
        <item amount="8" damage="5" material="wood"/>
        <item amount="8" material="leaves"/>
    </kill-reward>
</kill-rewards>
<hunger>
    <depletion>off</depletion>
</hunger>
<maxbuildheight>20</maxbuildheight>
</map>
