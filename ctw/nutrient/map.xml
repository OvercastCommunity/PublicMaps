<map proto="1.5.0">
<name>Nutrient</name>
<version>1.2.3</version>
<created>2016-10-26</created>
<objective>Capture the enemy team's two wools and place them on your victory monument!</objective>
<include id="gapple-kill-reward"/>
<authors>
    <author uuid="fe3608b7-d105-4029-8800-34b3147065b6"/> <!-- rockymine -->
</authors>
<teams>
    <team id="blue" color="blue" max="20">Blue</team>
    <team id="red" color="dark red" max="20">Red</team>
</teams>
<kits>
    <kit id="spawn-kit">
        <clear/>
        <item slot="0" unbreakable="true" material="stone sword"/>
        <item slot="1" unbreakable="true" material="bow">
            <enchantment>infinity</enchantment>
        </item>
        <item slot="28" material="arrow"/>
        <item slot="2" unbreakable="true" material="iron pickaxe">
            <enchantment>efficiency</enchantment>
        </item>
        <item slot="3" unbreakable="true" material="iron axe">
            <enchantment>efficiency</enchantment>
        </item>
        <item slot="4" unbreakable="true" material="iron spade"/>
        <item slot="31" unbreakable="true" material="shears">
            <enchantment>efficiency</enchantment>
        </item>
        <item slot="5" amount="64" damage="5" material="wood"/>
        <item slot="32" amount="64" damage="5" material="wood"/>
        <item slot="6" amount="64" material="leaves"/>
        <item slot="7" material="golden apple"/>
        <item slot="8" amount="64" material="golden carrot"/>
        <helmet unbreakable="true" team-color="true" material="leather helmet"/>
        <chestplate unbreakable="true" team-color="true" material="leather chestplate"/>
        <leggings unbreakable="true" material="chainmail leggings">
            <enchantment>projectile_protection</enchantment>
        </leggings>
        <boots unbreakable="true" material="iron boots"/>
        <effect duration="5" amplifier="255">heal</effect>
        <effect duration="5" amplifier="255">damage resistance</effect>
    </kit>
</kits>
<spawns>
    <default>
        <region yaw="45">
            <point>-58.5,41,244.5</point>
        </region>
        <region yaw="-135">
            <point>-58.5,41,244.5</point>
        </region>
    </default>
    <spawn team="blue" kit="spawn-kit">
        <region yaw="157.5">
            <point>-135.5,17,320.5</point>
        </region>
        <region yaw="-67.5">
            <point>-135.5,17,320.5</point>
        </region>
    </spawn>
    <spawn team="red" kit="spawn-kit">
        <region yaw="112.5">
            <point>17.5,17,168.5</point>
        </region>
        <region yaw="-22.5">
            <point>17.5,17,168.5</point>
        </region>
    </spawn>
</spawns>
<filters>
    <all id="blue-in-wr">
        <team id="only-blue">blue</team>
        <any>
            <material>web</material>
            <material>leaves</material>
        </any>
    </all>
    <all id="red-in-wr">
        <team id="only-red">red</team>
        <any>
            <material>web</material>
            <material>leaves</material>
        </any>
    </all>
    <not id="no-void">
        <void/>
    </not>
</filters>
<regions>
    <union id="spawns">
        <complement id="blue-spawn">
            <rectangle min="-100,339" max="-153,286"/>
            <rectangle min="-100,303" max="-117,286"/>
        </complement>
        <complement id="red-spawn">
            <rectangle min="-17,150" max="36,203"/>
            <rectangle min="-17,186" max="0,203"/>
        </complement>
    </union>
    <union id="wool-rooms">
        <union id="blue-wool-rooms">
            <!-- the wool rooms blue have to enter -->
            <rectangle id="yellow-grey-wool-room" min="-38,173" max="-16,150"/>
            <rectangle id="orange-blue-wool-room" min="13,224" max="36,202"/>
        </union>
        <union id="red-wool-rooms">
            <!-- the wool rooms red have to enter -->
            <rectangle id="purple-wool-room" min="-79,316" max="-101,339"/>
            <rectangle id="pink-wool-room" min="-130,265" max="-153,287"/>
        </union>
    </union>
    <complement id="non-bridge">
        <everywhere/>
        <rectangle min="-92,211" max="-53,250"/>
        <rectangle min="-25,278" max="-64,239"/>
    </complement>
    <!--  block and use regions  -->
    <apply enter="only-blue" region="blue-spawn" message="You may not enter the enemy team's spawn!"/>
    <apply enter="only-red" region="red-spawn" message="You may not enter the enemy team's spawn!"/>
    <apply enter="only-blue" region="blue-wool-rooms" message="You may not enter your team's own wool rooms!"/>
    <apply enter="only-red" region="red-wool-rooms" message="You may not enter your team's own wool rooms!"/>
    <apply block="never" region="spawns" message="You may not modify this area!"/>
    <apply block="blue-in-wr" use="only-blue" region="blue-wool-rooms"/>
    <apply block="red-in-wr" use="only-red" region="red-wool-rooms"/>
    <apply block-place="no-void" block-break="always" region="non-bridge" message="You may not modify the void area!"/>
</regions>
<wools>
    <wools team="blue">
        <wool color="orange" location="23.5,15,213.5">
            <monument>
                <block>-130,17,320</block>
            </monument>
        </wool>
        <wool color="yellow" location="-27.5,15,160.5">
            <monument>
                <block>-135,17,315</block>
            </monument>
        </wool>
    </wools>
    <wools team="red">
        <wool color="pink" location="-140.5,15,275.5">
            <monument>
                <block>12,17,168</block>
            </monument>
        </wool>
        <wool color="purple" location="-89.5,15,328.5">
            <monument>
                <block>17,17,173</block>
            </monument>
        </wool>
    </wools>
</wools>
<toolrepair>
    <tool>stone sword</tool>
    <tool>bow</tool>
    <tool>iron pickaxe</tool>
    <tool>iron axe</tool>
    <tool>iron spade</tool>
    <tool>arrow</tool>
    <tool>shears</tool>
</toolrepair>
<itemremove>
    <item>leather helmet</item>
    <item>leather chestplate</item>
    <item>chainmail leggings</item>
    <item>iron boots</item>
    <item>stone</item>
    <item>dirt</item>
    <item>red rose</item>
    <item>seeds</item>
    <item>sapling</item>
    <item>long grass</item>
    <item>golden carrot</item>
    <item>apple</item>
    <item>flint</item>
    <item>clay</item>
</itemremove>
<block-drops>
    <rule>
        <filter>
            <material>wood</material>
        </filter>
        <drops>
            <item chance="0" material="wood"/>
        </drops>
    </rule>
    <rule>
        <filter>
            <material>leaves</material>
        </filter>
        <drops>
            <item chance="0" material="leaves"/>
        </drops>
    </rule>
</block-drops>
<itemkeep>
    <item>wood</item>
    <item>leaves</item>
    <item>golden apple</item>
</itemkeep>
<kill-reward>
    <item amount="32" damage="5" material="wood"/>
    <item amount="16" material="leaves"/>
</kill-reward>
<maxbuildheight>25</maxbuildheight>
</map>
