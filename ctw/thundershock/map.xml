        </wool>
        <wool color="yellow" location="-62.5,12,-371.5">
            <monument>
                <block>-155,13,-187</block>
            </monument>
        </wool>
    </wools>
    <!-- yellow -->
    <wools team="yellow">
        <wool color="blue" location="76.5,12,-246.5">
            <monument>
                <block>-109,13,-339</block>
            </monument>
        </wool>
        <wool color="lime" location="-48.5,12,-107.5">
            <monument>
                <block>-108,13,-339</block>
            </monument>
        </wool>
        <wool color="red" location="-187.5,12,-232.5">
            <monument>
                <block>-107,13,-339</block>
            </monument>
        </wool>
    </wools>
</wools>
<toolrepair>
    <tool>stone sword</tool>
    <tool>bow</tool>
    <tool>iron pickaxe</tool>
    <tool>iron axe</tool>
    <tool>stone spade</tool>
    <tool>arrow</tool>
</toolrepair>
<itemremove>
    <item>stained clay</item>
    <item>wood</item>
    <item>grilled pork</item>
    <item>iron helmet</item>
    <item>chainmail chestplate</item>
    <item>leather leggings</item>
    <item>iron boots</item>
    <item>sandstone</item>
    <item>seeds</item>
    <item>sapling</item>
    <item>apple</item>
    <item>wood plate</item>
    <item>book</item>
    <item>gold plate</item>
    <item>sandstone stairs</item>
