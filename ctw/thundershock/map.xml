    <!-- red -->
    <wools team="red">
        <wool color="blue" location="76.5,12,-246.5">
            <monument>
                <block>-155,13,-188</block>
            </monument>
        </wool>
        <wool color="lime" location="-48.5,12,-107.5">
            <monument>
                <block>-155,13,-189</block>
