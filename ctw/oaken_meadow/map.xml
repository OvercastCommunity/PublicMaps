<map proto="1.5.0">
<name>Oaken Meadow</name>
<version>1.4.18</version>
<created>2016-07-06</created>
<objective>Capture both wools!</objective>
<phase>staging</phase>
<maxbuildheight>25</maxbuildheight>
<include id="iron-bulkcrafting"/>
<include id="gapple-kill-reward"/>
<authors>
    <author uuid="fe3608b7-d105-4029-8800-34b3147065b6"/> <!-- rockymine -->
</authors>
<contributors>
    <contributor uuid="e2d2c2c6-cea9-4510-9ab2-a091b5605b30" contribution="XML"/> <!-- Ruediger_LP -->
</contributors>
<teams>
    <team id="blue-team" color="blue" max="35">Blue</team>
    <team id="red-team" color="red" max="35">Red</team>
</teams>
<kits>
    <kit id="spawn-kit">
        <clear/>
        <item slot="0" material="iron sword" unbreakable="true"/>
        <item slot="1" material="bow" unbreakable="true" enchantment="arrow infinite"/>
        <item slot="2" material="iron pickaxe" unbreakable="true" enchantment="dig speed"/>
        <item slot="3" material="iron axe" unbreakable="true" enchantment="dig speed"/>
        <item slot="4" material="wood" damage="2" amount="64"/>
        <item slot="5" material="stained clay" team-color="true" amount="48"/>
        <item slot="6" material="vine" amount="24"/>
        <item slot="8" material="golden apple"/>
        <item slot="28" material="arrow"/>
        <item slot="29" material="shears" unbreakable="true"/>
        <item slot="30" material="iron spade" unbreakable="true"/>
        <chestplate material="leather chestplate" team-color="true" unbreakable="true"/>
        <leggings material="chainmail leggings" unbreakable="true"/>
        <boots material="leather boots" team-color="true" unbreakable="true"/>
        <effect amplifier="5">damage resistance</effect>
    </kit>
    <kit id="reset-resistance-kit" force="true">
        <effect duration="0" amplifier="0">damage resistance</effect>
    </kit>
</kits>
<spawns>
    <spawn team="blue-team" kit="spawn-kit" yaw="90" region="blue-spawn-point"/>
    <spawn team="red-team" kit="spawn-kit" yaw="-90" region="red-spawn-point"/>
    <default yaw="180" region="obs-spawn-point"/>
</spawns>
<wools craftable="false">
    <wool team="blue-team" color="magenta" monument="blue-team-magenta-wool" location="-50.5,20.2,87.5"/>
    <wool team="blue-team" color="pink" monument="blue-team-pink-wool" location="-33.5,20.2,-86.5"/>
    <wool team="red-team" color="lime" monument="red-team-lime-wool" location="50.5,20.2,-87.5"/>
    <wool team="red-team" color="green" monument="red-team-green-wool" location="33.5,20.2,86.5"/>
</wools>
<actions>
    <fill id="place-water-lanes" region="water-lanes" material="water" expose="true"/>
</actions>
<filters>
    <team id="only-blue">blue-team</team>
    <team id="only-red">red-team</team>
    <!-- A not-too-exhaustive list of fullblocks allowed in water lanes -->
    <any id="placeable-blocks">
        <material>leaves</material>
        <material>log</material>
        <material>dirt</material>
        <material>grass</material>
        <material>stone</material>
        <material>cobblestone</material>
        <material>wood</material>
        <material>stained clay</material>
        <material>wool</material>
    </any>
    <holding id="holding-bucket">
        <item>bucket</item>
        </holding>
    <all id="reds-woolrooms-filter">
        <team>blue-team</team>
        <filter id="woolrooms-filter"/>
    </all>
    <all id="blues-woolrooms-filter">
        <team>red-team</team>
        <filter id="woolrooms-filter"/>
    </all>
    <any id="woolrooms-filter">
        <material>web</material>
        <material>wood:2</material>
        <material>stained clay:14</material>
        <material>stained clay:11</material>
        <material>water</material>
        <material>stationary water</material>
    </any>
    <all id="only-iron-cause-world">
        <material id="only-iron">iron block</material>
        <cause>world</cause>
    </all>
    <material id="only-air">air</material>
    <deny id="deny-beacon">
        <material>beacon</material>
    </deny>
</filters>
<regions>
    <cylinder id="blue-spawn-point" base="106.5,13.5,8" radius="1" height="0"/>
    <cylinder id="red-spawn-point" base="-106.5,13.5,-8" radius="1" height="0"/>
    <cuboid id="obs-spawn-point" min="-10,4.5,47" max="-6,5.5,49"/>
    <block id="blue-team-magenta-wool">77,11,8</block>
    <block id="blue-team-pink-wool">77,11,7</block>
    <block id="red-team-lime-wool">-78,11,-9</block>
    <block id="red-team-green-wool">-78,11,-8</block>
    <point id="magenta-wool-spawn">-50.5,20.2,87.5</point>
    <point id="pink-wool-spawn">-33.5,20.2,-86.5</point>
    <point id="lime-wool-spawn">50.5,20.2,-87.5</point>
    <point id="green-wool-spawn">33.5,20.2,86.5</point>
    <negative id="not-spawns">
        <union id="spawns">
            <rectangle id="blue-spawn" min="110,25" max="93,-9"/>
            <rectangle id="red-spawn" min="-110,-25" max="-93,9"/>
        </union>
    </negative>
    <union id="woolrooms">
        <union id="blues-woolrooms"> <!-- blue defends / red attacks -->
            <rectangle id="lime-woolroom" min="59,-60" max="42,-98"/>
            <rectangle min="60,-60" max="59,-77"/>
            <rectangle id="green-woolroom" min="42,97" max="25,59"/>
            <rectangle min="43,76" max="42,59"/>
        </union>
        <union id="reds-woolrooms"> <!-- red defends / blue attacks -->
            <rectangle id="magenta-woolroom" min="-59,60" max="-42,98"/>
            <rectangle min="-60,60" max="-59,77"/>
            <rectangle id="pink-woolroom" min="-42,-97" max="-25,-59"/>
            <rectangle min="-43,-76" max="-42,-59"/>
        </union>
    </union>
    <negative id="not-build-area">
        <union id="build-area">
            <rectangle min="-30,-26" max="30,26"/> <!-- mid -->
            <rectangle min="-42,-8" max="-59,-25"/> <!-- red side parts -->
            <rectangle min="-59,26" max="-76,9"/>
            <rectangle min="42,8" max="59,25"/> <!-- blue side parts -->
            <rectangle min="59,-26" max="76,-9"/>
        </union>
    </negative>
    <union id="victory-monuments">
        <rectangle min="-79,-11" max="-76,-5"/> <!-- red victory monuments -->
        <rectangle min="79,11" max="76,5"/> <!-- blue victory monuments -->
    </union>
    <union id="water-lanes">
        <union id="red-water-lane">
            <cuboid min="-59,0,-59" max="-45,1,-42"/>
            <cuboid min="-76,0,43" max="-62,1,60"/>
        </union>
        <union id="blue-water-lane">
            <cuboid min="59,0,59" max="45,1,42"/>
            <cuboid min="76,0,-43" max="62,1,-60"/>
        </union>
    </union>
    <union id="obs-spawn">
        <rectangle min="17,-58" max="-7,-35"/>
        <rectangle min="-17,58" max="7,35"/>
    </union>
    <!-- applicators -->
    <apply use="only-red" region="blues-woolrooms"/>
    <apply use="only-blue" region="reds-woolrooms"/>
    <apply enter="only-blue" region="blue-spawn" message="You may not enter the enemy's spawn!"/>
    <apply enter="only-red" region="red-spawn" message="You may not enter the enemy's spawn!"/>
    <apply enter="only-red" region="blues-woolrooms" message="You may not enter your own wool room!"/>
    <apply enter="only-blue" region="reds-woolrooms" message="You may not enter your own wool room!"/>
    <apply block-place="only-iron-cause-world" block-break="only-iron" region="spawns" message="You may not edit spawn!"/>
    <apply block="blues-woolrooms-filter" region="blues-woolrooms" message="You may not edit the wool room!"/>
    <apply block="reds-woolrooms-filter" region="reds-woolrooms" message="You may not edit the wool room!"/>
    <apply block="never" region="victory-monuments" message="You may not edit the victory monument!"/>
    <apply block="never" region="obs-spawn" message="You may not edit the observer spawn!"/>
    <apply block-break="deny(holding-bucket)" region="water-lanes" message="You can't use buckets here!"/>
    <apply block-place="deny(not(placeable-blocks))" region="water-lanes" message="Only full blocks are allowed here!"/>
    <apply block-break="always"/>
    <apply block-place="deny(void)" region="not-build-area" message="You may not edit the void!"/>
    <apply kit="reset-resistance-kit" region="not-spawns"/>
    <apply use="deny-beacon" region="woolrooms"/>
</regions>
<spawners>
    <spawner spawn-region="magenta-wool-spawn" player-region="magenta-woolroom" delay="2s">
        <item material="wool" amount="1" damage="2"/>
    </spawner>
    <spawner spawn-region="pink-wool-spawn" player-region="pink-woolroom" delay="2s">
        <item material="wool" amount="1" damage="6"/>
    </spawner>
    <spawner spawn-region="lime-wool-spawn" player-region="lime-woolroom" delay="2s">
        <item material="wool" amount="1" damage="5"/>
    </spawner>
    <spawner spawn-region="green-wool-spawn" player-region="green-woolroom" delay="2s">
        <item material="wool" amount="1" damage="13"/>
    </spawner>
</spawners>
<modes>
    <mode name="`eWater lanes added" action="place-water-lanes" after="45m" show-before="5m"/>
</modes>
<itemkeep>
    <item>iron sword</item>
    <item>bow</item>
    <item>iron pickaxe</item>
    <item>iron axe</item>
    <item>arrow</item>
    <item>shears</item>
    <item>iron spade</item>
    <item>wood:2</item>
    <item>stained clay</item>
    <item>leaves</item>
    <item>vine</item>
    <item>golden apple</item>
</itemkeep>
<itemremove>
    <item>leather chestplate</item>
    <item>chainmail leggings</item>
    <item>leather boots</item>
    <item>red rose</item>
    <item>seeds</item>
    <item>sapling</item>
    <item>apple</item>
    <item>carpet</item>
    <item>long grass</item>
</itemremove>
<toolrepair>
    <tool>iron sword</tool>
    <tool>bow</tool>
    <tool>iron pickaxe</tool>
    <tool>iron axe</tool>
    <tool>arrow</tool>
    <tool>shears</tool>
    <tool>iron spade</tool>
</toolrepair>
<block-drops>
    <rule region="water-lanes">
        <replacement>stationary water</replacement>
    </rule>
</block-drops>
<renewables>
    <renewable rate="5" sound="false" region="spawns" renew-filter="only-iron" replace-filter="only-air" avoid-players="5"/>
</renewables>
<world>
    <timeset>6000</timeset>
</world>
<hunger>
    <depletion>off</depletion>
</hunger>
<kill-rewards>
    <kill-reward>
        <item material="wood" damage="2" amount="32"/>
        <item material="stained clay" team-color="true" amount="16"/>
    </kill-reward>
</kill-rewards>
</map>
