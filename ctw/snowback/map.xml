<map proto="1.5.0">
<name>Snowback</name>
<version>3.0.10</version>
<phase>staging</phase>
<objective>Capture both wools!</objective>
<gamemode>ctw</gamemode>
<created>2021-12-02</created>
<include id="gapple-kill-reward"/>
<authors>
    <author uuid="fe3608b7-d105-4029-8800-34b3147065b6" contribution="Original author"/> <!-- rockymine -->
    <author uuid="ec5ec930-5cf3-4f8a-ad9f-09056aeed71b" contribution="Christmasyfier"/> <!-- Tundren -->
    <author uuid="b2539be1-8f98-4375-b653-9d91cd04c30e" contribution="Christmasyfier"/> <!-- Mewzzy -->
</authors>
<contributors>
    <contributor uuid="e2d2c2c6-cea9-4510-9ab2-a091b5605b30" contribution="XML"/> <!-- Ruediger_LP -->
    <contributor uuid="75fd93dd-8e48-4698-81a2-97dae2ec5b5f" contribution="Critic"/> <!-- Pugzy -->
    <contributor uuid="621b2aa8-4e5f-4ed8-bd36-0ae2f8952a06" contribution="Critic"/> <!-- Strangey -->
    <contributor uuid="ba4a93aa-4935-4a71-bab2-a58f9a124e7b" contribution="XML and map fixing"/> <!-- ollyj -->
</contributors>
<teams>
    <team id="magenta-team" color="light purple" max="32">Reindeer</team>
    <team id="yellow-team" color="yellow" max="32">Elves</team>
</teams>
<kits>
    <kit id="spawn-kit">
        <clear/>
        <item slot="0" material="iron sword" unbreakable="true"/>
        <item slot="1" material="bow" unbreakable="true">
            <enchantment>infinity</enchantment>
        </item>
        <item slot="2" material="iron pickaxe" unbreakable="true">
            <enchantment>efficiency</enchantment>
        </item>
        <item slot="3" material="iron axe" unbreakable="true">
            <enchantment level="2">efficiency</enchantment>
        </item>
        <item slot="4" material="stained clay" amount="64" team-color="true"/>
        <item slot="5" material="stained clay" amount="64" team-color="true"/>
        <item slot="6" material="wood" amount="64"/>
        <item slot="8" material="golden apple"/>
        <item slot="28" material="arrow"/>
        <item slot="29" material="shears" unbreakable="true"/>
        <item slot="30" material="iron spade" unbreakable="true"/>
        <chestplate material="leather chestplate" team-color="true" unbreakable="true"/>
        <leggings material="chainmail leggings" unbreakable="true"/>
        <boots material="leather boots" team-color="true" unbreakable="true"/>
        <effect amplifier="100">damage resistance</effect>
    </kit>
    <kit force="true" id="reset-resistance-kit">
        <effect duration="0" amplifier="0">damage resistance</effect>
    </kit>
</kits>
<spawns>
    <spawn team="magenta-team" kit="spawn-kit" yaw="180" region="magenta-spawn-point"/>
    <spawn team="yellow-team" kit="spawn-kit" region="yellow-spawn-point"/>
    <default region="obs-spawn-point"/>
</spawns>
<wools craftable="false">
    <wool team="magenta-team" color="pink" monument="magenta-team-pink-wool" location="-57,19.2,-122"/>
    <wool team="magenta-team" color="magenta" monument="magenta-team-magenta-wool" location="57,19.2,-122"/>
    <wool team="yellow-team" color="blue" monument="yellow-team-blue-wool" location="57,19.2,122"/>
    <wool team="yellow-team" color="light blue" monument="yellow-team-light-blue-wool" location="-57,19.2,122"/>
</wools>
<filters>
    <any id="block-break-void-filter">
        <all>
            <any>
                <material>log</material>
                <material>snow</material>
                <material>snow block</material>
                <material>sandstone</material>
                <material>sandstone stairs</material>
                <material>nether brick</material>
                <material>nether brick stairs</material>
                <material>step</material>
                <material>quartz block</material>
                <material>leaves</material>
            </any>
            <void/>
        </all>
        <not id="block-place-void-filter">
            <void/>
        </not>
    </any>
    <all id="yellows-woolrooms-filter">
        <team id="only-magenta">magenta-team</team>
        <filter id="woolrooms-filter"/>
    </all>
    <all id="magentas-woolrooms-filter">
        <team id="only-yellow">yellow-team</team>
        <filter id="woolrooms-filter"/>
    </all>
    <any id="woolrooms-filter">
        <material>web</material>
        <material>wood:0</material>
        <material>stained clay:2</material>
        <material>stained clay:4</material>
    </any>
    <all id="only-iron-cause-world">
        <material id="only-iron">iron block</material>
        <cause>world</cause>
    </all>
    <material id="only-air">air</material>
</filters>
<regions>
    <cylinder id="magenta-spawn-point" base="0,13.5,106.5" radius="1" height="0"/>
    <cylinder id="yellow-spawn-point" base="0,13.5,-106.5" radius="1" height="0"/>
    <cylinder id="obs-spawn-point" base="0,43.5,0" radius="1" height="0"/>
    <block id="magenta-team-pink-wool">-3,14,100</block>
    <block id="magenta-team-magenta-wool">2,14,100</block>
    <block id="yellow-team-blue-wool">2,14,-101</block>
    <block id="yellow-team-light-blue-wool">-3,14,-101</block>
    <point id="pink-wool-spawn">-57,19.2,-122</point>
    <point id="magenta-wool-spawn">57,19.2,-122</point>
    <point id="blue-wool-spawn">57,19.2,122</point>
    <point id="light-blue-wool-spawn">-57,19.2,122</point>
    <negative id="not-spawns">
        <union id="spawns">
            <rectangle id="magenta-spawn" min="-10,90" max="10,122"/>
            <rectangle id="yellow-spawn" min="-10,-122" max="10,-90"/>
        </union>
    </negative>
    <union id="magentas-woolrooms"> <!-- magenta defends / yellow attacks -->
        <rectangle id="blue-woolroom" min="30,114" max="70,130"/>
        <rectangle id="light-blue-woolroom" min="-70,114" max="-30,130"/>
    </union>
    <union id="yellows-woolrooms"> <!-- yellow defends / magenta attacks -->
        <rectangle id="pink-woolroom" min="-70,-130" max="-30,-114"/>
        <rectangle id="magenta-woolroom" min="30,-114" max="70,-130"/>
    </union>
    <negative id="not-build-area">
        <rectangle id="build-area" min="-70,-58" max="70,58"/> <!-- mid -->
    </negative>
    <!-- applicators -->
    <apply enter="only-magenta" region="magenta-spawn" message="You may not enter the enemy's spawn!"/>
    <apply enter="only-yellow" region="yellow-spawn" message="You may not enter the enemy's spawn!"/>
    <apply enter="only-yellow" region="magentas-woolrooms" message="You may not enter your own wool room!"/>
    <apply enter="only-magenta" region="yellows-woolrooms" message="You may not enter your own wool room!"/>
    <apply block-place="only-iron-cause-world" block-break="only-iron" region="spawns" message="You may not edit spawn!"/>
    <apply block="magentas-woolrooms-filter" region="magentas-woolrooms" message="You may not edit the wool room!"/>
    <apply block="yellows-woolrooms-filter" region="yellows-woolrooms" message="You may not edit the wool room!"/>
    <apply block-place="block-place-void-filter" block-break="block-break-void-filter" region="not-build-area" message="You may not edit the void!"/>
    <apply kit="reset-resistance-kit" region="not-spawns"/>
</regions>
<spawners>
    <spawner spawn-region="pink-wool-spawn" player-region="pink-woolroom" delay="3s">
        <item material="wool" amount="2" damage="6"/>
    </spawner>
    <spawner spawn-region="magenta-wool-spawn" player-region="magenta-woolroom" delay="3s">
        <item material="wool" amount="2" damage="2"/>
    </spawner>
    <spawner spawn-region="blue-wool-spawn" player-region="blue-woolroom" delay="3s">
        <item material="wool" amount="2" damage="11"/>
    </spawner>
    <spawner spawn-region="light-blue-wool-spawn" player-region="light-blue-woolroom" delay="3s">
        <item material="wool" amount="2" damage="3"/>
    </spawner>
</spawners>
<itemkeep>
    <item>iron sword</item>
    <item>bow</item>
    <item>iron pickaxe</item>
    <item>iron axe</item>
    <item>shears</item>
    <item>arrow</item>
    <item>iron spade</item>
    <item>wood</item>
    <item>stained clay</item>
    <item>golden apple</item>
</itemkeep>
<itemremove>
    <item>leather chestplate</item>
    <item>chainmail leggings</item>
    <item>leather boots</item>
    <item>stone</item>
    <item>wool:4</item>
    <item>wool:10</item>
    <item>carpet</item>
    <item>step</item>
    <item>stone slab2</item>
    <item>cobblestone</item>
    <item>cobblestone stairs</item>
    <item>quartz stairs</item>
    <item>quartz block</item>
    <item>stained clay:3</item>
    <item>stained clay:5</item>
    <item>stained clay:14</item>
    <item>gravel</item>
    <item>flint</item>
    <item>brick</item>
    <item>brick stairs</item>
    <item>sandstone</item>
    <item>sandstone stairs</item>
    <item>red sandstone</item>
    <item>red sandstone stairs</item>
    <item>nether brick</item>
    <item>nether brick stairs</item>
    <item>sapling</item>
    <item>long grass</item>
    <item>seeds</item>
    <item>red rose</item>
    <item>skull item</item>
    <item>dirt</item>
    <item>flower pot item</item>
    <item>torch</item>
    <item>lever</item>
</itemremove>
<toolrepair>
    <tool>iron sword</tool>
    <tool>bow</tool>
    <tool>iron pickaxe</tool>
    <tool>iron axe</tool>
    <tool>arrow</tool>
    <tool>shears</tool>
    <tool>iron spade</tool>
</toolrepair>
<block-drops>
    <rule>
        <filter>
            <material>wood</material>
        </filter>
        <drops>
            <item chance="0" material="wood"/>
        </drops>
    </rule>
    <rule>
        <filter>
            <material>stained clay</material>
        </filter>
        <drops>
            <item chance="0" material="stained clay"/>
        </drops>
    </rule>
    <rule>
        <filter>
            <material>snow block</material>
        </filter>
        <drops>
            <item material="snow block"/>
        </drops>
    </rule>
    <rule>
        <filter>
            <material>snow</material>
        </filter>
        <drops>
            <item chance="0" material="snow block"/>
        </drops>
    </rule>
</block-drops>
<item-mods>
    <rule>
        <match>
            <material>iron helmet</material>
            <material>iron chestplate</material>
            <material>iron leggings</material>
            <material>iron boots</material>
            <material>iron sword</material>
            <material>iron pickaxe</material>
            <material>iron axe</material>
            <material>iron spade</material>
            <material>shears</material>
            <material>diamond chestplate</material>
        </match>
        <modify unbreakable="true"/>
    </rule>
</item-mods>
<crafting>
    <!-- bulkcrafting -->
    <shaped override="false">
        <result material="iron helmet" amount="9"/>
        <shape>
            <row>III</row>
            <row>I.I</row>
        </shape>
        <ingredient symbol="I">iron block</ingredient>
    </shaped>
    <shaped override="false">
        <result material="iron chestplate" amount="9"/>
        <shape>
            <row>I.I</row>
            <row>III</row>
            <row>III</row>
        </shape>
        <ingredient symbol="I">iron block</ingredient>
    </shaped>
    <shaped override="false">
        <result material="iron leggings" amount="9"/>
        <shape>
            <row>III</row>
            <row>I.I</row>
            <row>I.I</row>
        </shape>
        <ingredient symbol="I">iron block</ingredient>
    </shaped>
    <shaped override="false">
        <result material="bucket" amount="9"/>
        <shape>
            <row>I.I</row>
            <row>.I.</row>
        </shape>
        <ingredient symbol="I">iron block</ingredient>
    </shaped>
</crafting>
<renewables>
    <renewable rate="0.5" sound="false" region="spawns" renew-filter="only-iron" replace-filter="only-air" avoid-players="5"/>
</renewables>
<hunger>
    <depletion>off</depletion>
</hunger>
<maxbuildheight>35</maxbuildheight>
<kill-rewards>
    <kill-reward>
        <item material="wood" amount="16"/>
        <item material="stained clay" team-color="true" amount="32"/>
    </kill-reward>
</kill-rewards>
</map>
