<map proto="1.5.0">
<name>Last Overcastian</name>
<version>1.0.9</version>
<created>2017-01-18</created>
<objective>Capture the enemy teams wools!</objective>
<include id="gapple-kill-reward"/>
<authors>
    <author uuid="fe3608b7-d105-4029-8800-34b3147065b6"/> <!-- rockymine -->
    <author uuid="7cbf2168-7f49-4fb3-aea8-6df8048a7ade"/> <!-- nigges60 -->
</authors>
<teams>
    <team id="blue-team" color="blue" max="32">Blue</team>
    <team id="red-team" color="dark red" max="32">Red</team>
</teams>
<kits>
    <kit id="spawn-kit">
        <clear/>
        <item slot="0" unbreakable="true" material="iron sword"/>
        <item slot="1" unbreakable="true" material="bow">
            <enchantment>infinity</enchantment>
        </item>
        <item slot="28" material="arrow"/>
        <item slot="2" unbreakable="true" material="iron pickaxe">
            <enchantment>efficiency</enchantment>
        </item>
        <item slot="29" unbreakable="true" material="iron spade"/>
        <item slot="3" unbreakable="true" material="iron axe">
            <enchantment>efficiency</enchantment>
        </item>
        <item slot="30" unbreakable="true" material="shears">
            <enchantment level="2">efficiency</enchantment>
        </item>
        <item slot="4" amount="64" damage="2" material="wood"/>
        <item slot="31" amount="64" damage="2" material="wood"/>
        <item slot="5" amount="64" material="glass"/>
        <item slot="8" material="golden apple"/>
        <helmet unbreakable="true" team-color="true" material="leather helmet"/>
        <chestplate unbreakable="true" team-color="true" material="leather chestplate"/>
        <leggings unbreakable="true" team-color="true" material="leather leggings"/>
        <boots unbreakable="true" team-color="true" material="leather boots"/>
        <effect duration="6s" amplifier="5">resistance</effect>
    </kit>
</kits>
<spawns>
    <default>
        <region yaw="90">
            <point>-10.5,34,30.5</point>
        </region>
    </default>
    <spawn team="blue-team" kit="spawn-kit">
        <regions yaw="-180">
            <point>3.5,19,161.5</point>
            <point>-24.5,19,161.5</point>
        </regions>
    </spawn>
    <spawn team="red-team" kit="spawn-kit">
        <regions>
            <point>-24.5,19,-100.5</point>
            <point>3.5,19,-100.5</point>
        </regions>
    </spawn>
</spawns>
<filters>
    <blocks id="wool-room-blocks" region="wool-rooms">
        <any>
            <material>web</material>
            <material>stained glass:3</material>
            <material>stained glass:6</material>
            <material>stained glass:10</material>
            <material>stained glass:13</material>
            <material>wood:0</material>
            <material>wood:2</material>
            <material>glass</material>
        </any>
    </blocks>
    <all id="only-iron-regen">
        <cause>world</cause>
        <material id="only-iron">iron block</material>
    </all>
    <material id="leaves">leaves</material>
</filters>
<regions>
    <complement id="void-area">
        <everywhere/>
        <complement>
            <union>
                <rectangle id="b-first" min="7,69" max="-28,86"/>
                <rectangle id="b-second" min="28,103" max="-49,120"/>
                <rectangle id="center" min="-62,49" max="41,12"/>
                <rectangle id="r-first" min="-28,-8" max="7,-25"/>
                <rectangle id="r-second" min="-49,-42" max="28,-59"/>
            </union>
            <cylinder id="obs-spawn" base="-10.5,29,30.5" height="8" radius="5.5"/>
        </complement>
    </complement>
    <union id="spawns">
        <rectangle id="blue-spawn" min="-66,127" max="45,171"/>
        <rectangle id="red-spawn" min="45,-66" max="-66,-110"/>
    </union>
    <union id="wool-rooms">
        <!-- Wools defended by blue-team -->
        <union id="blue-wools">
            <union id="cyan-wool">
                <cuboid min="-7,0,106" max="-14,25,117"/>
                <cuboid min="-4,0,107" max="-17,25,116"/>
                <cuboid min="-20,0,108" max="-19,25,115"/>
                <cuboid min="-1,0,110" max="-20,25,113"/>
            </union>
            <cuboid id="green-wool" min="-95,0,120" max="-114,25,103"/>
            <cuboid id="light-blue-wool" min="74,0,103" max="93,25,120"/>
        </union>
        <!-- Wools defended by red-team -->
        <union id="red-wools">
            <union id="magenta-wool">
                <cuboid min="-14,0,-45" max="-7,25,-56"/>
                <cuboid min="-17,0,-46" max="-4,25,-55"/>
                <cuboid min="-19,0,-47" max="-2,25,-54"/>
                <cuboid min="-20,0,-49" max="-1,25,-52"/>
            </union>
            <cuboid id="pink-wool" min="74,0,-59" max="93,25,42"/>
            <cuboid id="purple-wool" min="-95,0,-42" max="-114,25,-59"/>
        </union>
    </union>
    <apply use="deny(blue-team)" region="blue-wools"/>
    <apply use="deny(red-team)" region="red-wools"/>
    <apply use="deny(blue-team)" region="red-spawn"/>
    <apply use="deny(red-team)" region="blue-spawn"/>
    <apply enter="deny(blue-team)" region="red-spawn" message="You may not enter the enemy team's spawn!"/>
    <apply enter="deny(red-team)" region="blue-spawn" message="You may not enter the enemy team's spawn!"/>
    <apply enter="deny(blue-team)" region="blue-wools" message="You may not enter your team's own wool rooms!"/>
    <apply enter="deny(red-team)" region="red-wools" message="You may not enter your team's own wool rooms!"/>
    <apply block="wool-room-blocks" region="wool-rooms" message="You may not break this block in the wool rooms!"/>
    <apply block="deny(blue-team)" region="blue-wools" message="You may not interfere with your team's own wool rooms!"/>
    <apply block="deny(red-team)" region="red-wools" message="You may not interfere with your team's own wool rooms!"/>
    <apply block-place="only-iron-regen" block-break="only-iron" region="spawns" message="You may only break iron blocks in spawn!"/>
    <apply block-place="deny(void)" block-break="any(not(void),all(void,leaves))" region="void-area" message="You may not modify the void area!"/>
</regions>
<renewables>
    <renewable region="spawns" renew-filter="only-iron"/>
</renewables>
<wools>
    <wools team="blue-team">
        <wool color="magenta" location="-10.5,17,-50.5">
            <monument>
                <block>-11,19,152</block>
            </monument>
        </wool>
        <wool color="pink" location="86.5,17,-50.5">
            <monument>
                <block>-11,19,151</block>
            </monument>
        </wool>
        <wool color="purple" location="-107.5,17,-50.5">
            <monument>
                <block>-11,19,153</block>
            </monument>
        </wool>
    </wools>
    <wools team="red-team">
        <wool color="cyan" location="-10.5,17,111.5">
            <monument>
                <block>-11,19,-92</block>
            </monument>
        </wool>
        <wool color="green" location="-107.5,17,111.5">
            <monument>
                <block>-11,19,-93</block>
            </monument>
        </wool>
        <wool color="light blue" location="86.5,17,111.5">
            <monument>
                <block>-11,19,-91</block>
            </monument>
        </wool>
    </wools>
</wools>
<toolrepair>
    <tool>iron sword</tool>
    <tool>bow</tool>
    <tool>iron axe</tool>
    <tool>iron pickaxe</tool>
    <tool>iron spade</tool>
    <tool>arrow</tool>
    <tool>shears</tool>
</toolrepair>
<itemremove>
    <item>leather helmet</item>
    <item>leather chestplate</item>
    <item>leather leggings</item>
    <item>leather boots</item>
    <item>red rose</item>
    <item>seeds</item>
    <item>sapling</item>
    <item>apple</item>
    <item>long grass</item>
    <item>yellow flower</item>
    <item>gravel</item>
    <item>flint</item>
    <item>string</item>
    <item>carpet</item>
    <item>spruce wood stairs</item>
</itemremove>
<itemkeep>
    <item>golden apple</item>
    <item>wood</item>
    <item>glass</item>
</itemkeep>
<kill-rewards>
    <kill-reward>
        <item amount="32" damage="2" material="wood"/>
        <item amount="16" material="glass"/>
    </kill-reward>
</kill-rewards>
<maxbuildheight>25</maxbuildheight>
<hunger>
    <depletion>off</depletion>
</hunger>
</map>
