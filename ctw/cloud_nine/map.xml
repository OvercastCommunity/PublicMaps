<map proto="1.5.0">
<name>Cloud Nine</name>
<variant id="rage">PearlBow RAGE</variant>
<version>1.3.1</version>
<objective>Collect wool dyes from the shrines, and the string from killing players. Craft the colored wool and place it on your monument!</objective>
<if variant="rage">
    <created>2014-07-16</created>
    <phase>staging</phase>
    <rage/>
</if>
<authors>
    <author uuid="2fa85349-2276-4850-b7b5-d18c4f4c8376"/> <!-- Solo_Runner -->
</authors>
<contributors>
    <contributor uuid="4978504c-ba2f-4b93-9890-38fbaa8e0b5e" contribution="XML"/> <!-- Hydro_Seeds -->
    <if variant="rage">
        <contributor uuid="2ca8072f-74be-4798-85b8-bbce03aa91af" contribution="Ragification"/> <!-- Tywnis -->
    </if>
</contributors>
<teams>
    <team id="blue-team" color="blue" max="16">Blue</team>
    <team id="red-team" color="dark red" max="16">Red</team>
</teams>
<kits>
    <kit id="default-kit">
        <effect>night vision</effect>
    </kit>
    <kit id="speed-kit">
        <effect>speed</effect>
    </kit>
    <kit id="spawn-kit" parents="default-kit,speed-kit">
        <if variant="default">
            <item slot="0" material="stone sword"/>
            <item slot="1" material="bow"/>
            <!-- <item slot="3" amount="16" material="snow ball"/> -->
            <item slot="8" amount="12" material="arrow"/>
        </if>
        <if variant="rage">
            <item slot="0" unbreakable="true" enchantment="damage all:10" lore="`r`aDual-purpose teleporter and melee weapon" material="bow"/>
            <item slot="1" amount="16" material="snow ball"/>
            <item slot="28" amount="5" material="arrow"/>
        </if>
        <helmet team-color="true" unbreakable="true" material="leather helmet"/>
        <chestplate team-color="true" unbreakable="true" material="leather chestplate"/>
        <leggings team-color="true" unbreakable="true" material="leather leggings"/>
        <boots team-color="true" unbreakable="true" material="leather boots"/>
        <effect duration="3s" amplifier="5">damage resistance</effect>
    </kit>
    <give kit="speed-kit" filter="all(participating,not(dyes))"/>
    <take kit="speed-kit" filter="all(participating,dyes)"/>
</kits>
<spawns>
    <default kit="default-kit">
        <region>
            <cylinder base="0.5,54,0.5" radius="2" height="0"/>
        </region>
    </default>
    <spawn team="blue-team" kit="spawn-kit">
        <region>
            <cylinder base="0.5,19,-41.5" radius="2" height="0"/>
        </region>
    </spawn>
    <spawn team="red-team" kit="spawn-kit">
        <region yaw="180">
            <cylinder base="0.5,19,42.5" radius="2" height="0"/>
        </region>
    </spawn>
</spawns>
<regions>
    <union id="dyes">
        <circle id="lime-dye" center="44.5,0.5" radius="6"/>
        <circle id="purple-dye" center="0.5,0.5" radius="11"/>
        <circle id="yellow-dye" center="-43.5,0.5" radius="6"/>
    </union>
    <union id="wool-monuments">
        <union id="blue-wool-monuments">
            <block id="lime-monument-blue">-20.5,15,-41.5</block>
            <block id="purple-monument-blue">0.5,15,-62.5</block>
            <block id="yellow-monument-blue">21.5,15,-41.5</block>
        </union>
        <union id="red-wool-monuments">
            <block id="lime-monument-red">-20.5,15,42.5</block>
            <block id="purple-monument-red">0.5,15,63.5</block>
            <block id="yellow-monument-red">21.5,15,42.5</block>
        </union>
    </union>
    <apply block="never"/>
</regions>
<wools craftable="true">
    <wools team="blue-team">
        <wool color="lime" location="44.5,19,0.5" monument="lime-monument-blue"/>
        <wool color="purple" location="0.5,4,0.5" monument="purple-monument-blue"/>
        <wool color="yellow" location="-43.5,19,0.5" monument="yellow-monument-blue"/>
    </wools>
    <wools team="red-team">
        <wool color="lime" location="44.5,19,0.5" monument="lime-monument-red"/>
        <wool color="purple" location="0.5,4,0.5" monument="purple-monument-red"/>
        <wool color="yellow" location="-43.5,19,0.5" monument="yellow-monument-red"/>
    </wools>
</wools>
<toolrepair>
    <tool>stone sword</tool>
    <tool>bow</tool>
</toolrepair>
<itemremove>
    <item>leather helmet</item>
    <item>leather chestplate</item>
    <item>leather leggings</item>
    <item>leather boots</item>
    <item>string</item>
    <item>snow ball</item>
    <item>arrow</item>
    <item>wool</item>
</itemremove>
<kill-rewards>
    <kill-reward>
        <item material="string"/>
        <if variant="default">
            <item amount="6" material="arrow"/>
            <kit>
                <effect duration="2.5s" amplifier="4">regeneration</effect>
            </kit>
        </if>
        <if variant="rage">
            <item amount="2" material="arrow"/>
        </if>
    </kill-reward>
</kill-rewards>
<modifybowprojectile>
    <if variant="default">
        <projectile>Snowball</projectile>
    </if>
    <if variant="rage">
        <projectile>EnderPearl</projectile>
        <potion duration="5s">confusion</potion>
        <potion duration="2s">blindness</potion>
        <potion amplifier="99" duration="1s">slow</potion>
    </if>
</modifybowprojectile>
<hunger>
    <depletion>off</depletion>
</hunger>
</map>
